<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default States Mapping -->
        
        <record id="state_pending" model="student.service.request.state">
            <field name="name">Chờ duyệt</field>
            <field name="code">pending</field>
            <field name="type">pending</field>
            <field name="sequence">10</field>
            <field name="color">1</field>
        </record>

        <record id="state_approved" model="student.service.request.state">
            <field name="name">Đã duyệt</field>
            <field name="code">approved</field>
            <field name="type">approved</field>
            <field name="sequence">20</field>
            <field name="color">10</field> <!-- Green -->
        </record>

        <record id="state_rejected" model="student.service.request.state">
            <field name="name">Từ chối</field>
            <field name="code">rejected</field>
            <field name="type">rejected</field>
            <field name="sequence">90</field>
            <field name="color">9</field> <!-- Red -->
        </record>

        <record id="state_repairing" model="student.service.request.state">
            <field name="name">Chờ sửa chữa</field>
            <field name="code">repairing</field>
            <field name="type">repairing</field>
            <field name="sequence">15</field>
            <field name="color">4</field> <!-- Blue/Info -->
        </record>

        <record id="state_assigned" model="student.service.request.state">
            <field name="name">Đã phân công</field>
            <field name="code">assigned</field>
            <field name="type">assigned</field>
            <field name="sequence">12</field>
            <field name="color">4</field>
        </record>

        <record id="state_extended" model="student.service.request.state">
            <field name="name">Đã gia hạn</field>
            <field name="code">extended</field>
            <field name="type">extended</field>
            <field name="sequence">18</field>
            <field name="color">3</field> <!-- Yellow -->
        </record>

        <record id="state_cancelled" model="student.service.request.state">
            <field name="name">Đã hủy</field>
            <field name="code">cancelled</field>
            <field name="type">cancelled</field>
            <field name="sequence">99</field>
            <field name="color">9</field>
        </record>

        <record id="state_ignored" model="student.service.request.state">
            <field name="name">Đã bỏ qua</field>
            <field name="code">ignored</field>
            <field name="type">ignored</field>
            <field name="sequence">80</field>
            <field name="color">2</field>
        </record>

        <record id="state_adjust_profile" model="student.service.request.state">
            <field name="name">Điều chỉnh hồ sơ</field>
            <field name="code">adjust_profile</field>
            <field name="type">adjust_profile</field>
            <field name="sequence">16</field>
            <field name="color">3</field>
        </record>

        <record id="state_closed" model="student.service.request.state">
            <field name="name">Đã đóng</field>
            <field name="code">closed</field>
            <field name="type">closed</field>
            <field name="sequence">100</field>
            <field name="color">11</field> <!-- Purple? -->
        </record>

    </data>
</odoo>
