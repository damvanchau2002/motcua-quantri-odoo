<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view -->
    <record id="view_service_form_field_tree" model="ir.ui.view">
        <field name="name">student.service.form.field.tree</field>
        <field name="model">student.service.form.field</field>
        <field name="arch" type="xml">
            <list string="Form Fields" editable="bottom">
                <field name="sequence"/>
                <field name="name" required="1"/>
                <field name="label" required="1"/>
                <field name="field_type" required="1"/>
                <field name="placeholder"/>
                <field name="required"/>
                <field name="options" invisible="field_type != 'select'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_service_form_field_form" model="ir.ui.view">
        <field name="name">student.service.form.field.form</field>
        <field name="model">student.service.form.field</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="label"/>
                            <field name="field_type"/>
                        </group>
                        <group>
                            <field name="required"/>
                            <field name="sequence"/>
                            <field name="placeholder"/>
                        </group>
                    </group>
                    <group invisible="field_type != 'select'">
                        <field name="options" placeholder="Nhập mỗi option trên 1 dòng&#10;VD:&#10;CMND/CCCD&#10;Bằng lái xe&#10;Giấy khám SK"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
