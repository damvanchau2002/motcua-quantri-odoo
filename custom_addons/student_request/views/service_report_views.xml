<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_student_service_report_wizard_form" model="ir.ui.view">
        <field name="name">student.service.report.wizard.form</field>
        <field name="model">student.service.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Báo cáo thống kê yêu cầu" create="false" edit="true">

                <!-- ===== Header Buttons ===== -->
                <header>
                    <button name="action_generate_report"
                            string="Lọc báo cáo"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_export_excel"
                            string="Xuất Excel"
                            type="object"
                            class="btn-secondary"
                            invisible="not report_line_ids"/>
                </header>

                <sheet>

                    <!-- ===== PANEL: Bộ lọc ===== -->
                    <group string="🎯 Bộ lọc báo cáo" col="2" class="o_inner_group">
                        <group>
                            <field name="mode"/>
                        </group>
                        <group>
                            <!-- Lọc theo ngày -->
                            <field name="from_date"
                                   invisible="mode != 'day'"
                                   placeholder="dd/mm/yyyy"
                                   options="{'datepicker': {'format': 'DD/MM/YYYY'}}"/>
                            <field name="to_date"
                                   invisible="mode != 'day'"
                                   placeholder="dd/mm/yyyy"
                                   options="{'datepicker': {'format': 'DD/MM/YYYY'}}"/>

                            <!-- Lọc theo tháng -->
                            <field name="from_month"
                                   widget="month_selection"
                                   invisible="mode != 'month'"
                                   placeholder="mm/yyyy"/>
                            <field name="to_month"
                                   widget="month_selection"
                                   invisible="mode != 'month'"
                                   placeholder="mm/yyyy"/>

                            <!-- Lọc theo năm -->
                            <field name="from_year" invisible="mode != 'year'"/>
                            <field name="to_year" invisible="mode != 'year'"/>
                        </group>
                    </group>

                    <separator string=""/>

                    <!-- ===== PANEL: Kết quả báo cáo ===== -->
                    <group string="📊 Kết quả thống kê" class="o_inner_group">
                        <field name="report_line_ids" nolabel="1">
                            <list string="Kết quả báo cáo"
                                  create="false"
                                  edit="false"
                                  delete="false">
                                <field name="period"/>
                                <field name="area_name"/>
                                <field name="cluster_name"/>
                                <field name="group_name"/>
                                <field name="service_name"/>
                                <field name="total_requests"/>
                                <field name="processed_requests"/>
                                <field name="pending_requests"/>
                                <field name="overdue_requests"/>
                                <field name="processed_percent"/>
                            </list>
                        </field>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Action mở wizard -->
    <record id="action_student_service_report_wizard" model="ir.actions.act_window">
        <field name="name">Báo cáo yêu cầu</field>
        <field name="res_model">student.service.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_student_service_report_wizard_form"/>
        <!-- Hiển thị toàn trang -->
        <field name="target">main</field>
        <field name="context">{'lang':'vi_VN'}</field>
    </record>
</odoo>
