<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- === REQUEST === -->
    <!-- Popup Nghiệm thu cho Admin  -->
    <record id="view_temporary_wizard_form" model="ir.ui.view">
        <field name="name">temporary.wizard.form</field>
        <field name="model">temporary.wizard</field>
        <field name="arch" type="xml">
            <form string="Nghiệm thu Yêu cầu">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="user_id"  readonly="1" widget="many2one"/>
                    <hr/>
                    <field name="note"/>
                    <field name="star"/>
                    <field name="action"/>
                    <field name="user_accept" readonly="1"/>
                </group>
                <footer>
                    <button string="Xác nhận" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Đóng" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_temporary_wizard" model="ir.actions.act_window">
        <field name="name">Nghiệm thu Yêu cầu</field>
        <field name="res_model">temporary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- View form cho bước duyệt (Popup) -->
    <record id="view_service_request_step_form" model="ir.ui.view">
        <field name="name">student.service.request.step.form</field>
        <field name="model">student.service.request.step</field>
        <field name="arch" type="xml">
            <form string="Chi tiết bước duyệt">
                <header>
                    <button name="action_confirm_approve" string="Xác nhận" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="display_step_name" readonly="1"/>
                            <field name="assign_user_id" options="{'no_create': True}"/>
                            <field name="department_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="available_status_ids" invisible="1"/>
                            <field name="status_id" options="{'no_create': True}" domain="[('id', 'in', available_status_ids)]"/>
                            <field name="state" readonly="1" force_save="1"/>
                            <field name="approve_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Nội dung duyệt">
                        <field name="approve_content"/>
                        <field name="final_data" invisible="base_secquence != 99"/>
                    </group>
                    <notebook>
                        <page string="File đính kèm" invisible="not file_checkbox_ids">
                             <field name="file_checkbox_ids">
                                <list editable="bottom">
                                    <field name="file_id" readonly="1"/>
                                    <field name="checked"/>
                                </list>
                             </field>
                        </page>
                        <page string="Lịch sử">
                            <field name="history_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="user_id"/>
                                    <field name="status_id"/>
                                    <field name="state"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View form tạo yêu cầu dịch vụ -->
    <record id="view_service_request_form" model="ir.ui.view">
        <field name="name">student.service.request.form</field>
        <field name="model">student.service.request</field> 
        <field name="arch" type="xml">
            <form delete="false">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_extensions" type="object" 
                                class="oe_stat_button" icon="fa-clock-o"
                                invisible="extension_count == 0">
                            <field name="extension_count" widget="statinfo" string="Gia hạn"/>
                        </button>
                    </div>
                    
                 <!--    <header>
                        Tạo yêu cầu mới:
                        <button name="action_request_extension" type="object" 
                                string="Yêu cầu gia hạn" class="btn-warning"
                                invisible="final_state in ['closed', 'approved', 'cancelled'] or not expired_date"
                                help="Yêu cầu gia hạn thời gian xử lý"/>
                    </header> -->
                    <group>
                        <group string="Nội dung yêu cầu">
                            <field name="service_id"/>
                            <field name="service_titlenote" invisible="not service_titlenote"/>
                            <field name="image_attachment_ids" widget="many2many" mode="kanban" string="Ảnh đính kèm (Sinh viên)">
                                <kanban>
                                    <field name="name"/>
                                    <field name="datas"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click" style="display: inline-block; margin: 5px;">
                                                <img t-att-src="'/web/image/ir.attachment/' + record.id.raw_value + '/datas'" 
                                                    style="max-width: 150px; max-height: 150px; cursor: pointer;"/>
                                                <div class="oe_kanban_details" style="text-align: center;">
                                                    <field name="name"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form>
                                    <sheet>
                                        <field name="name"/>
                                        <field name="datas" widget="image"/>
                                    </sheet>
                                </form>
                            </field>
                            <field name="processor_image_attachment_ids" widget="many2many" mode="kanban" string="Ảnh đính kèm (Cán bộ)">
                                <kanban>
                                    <field name="name"/>
                                    <field name="datas"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click" style="display: inline-block; margin: 5px;">
                                                <img t-att-src="'/web/image/ir.attachment/' + record.id.raw_value + '/datas'" 
                                                    style="max-width: 150px; max-height: 150px; cursor: pointer;"/>
                                                <div class="oe_kanban_details" style="text-align: center;">
                                                    <field name="name"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form>
                                    <sheet>
                                        <field name="name"/>
                                        <field name="datas" widget="image"/>
                                    </sheet>
                                </form>
                            </field>
                            <field name="note"/>
                            <!-- Dynamic Input Table -->
                            <field name="input_ids" nolabel="1" colspan="2">
                                <list create="0" delete="0" decoration-muted="not required">
                                    <field name="sequence" widget="handle"/>
                                    <field name="label" string="Tên trường"/>
                                    <field name="value_display" string="Giá trị hiển thị" decoration-bf="1"/>
                                    <field name="field_type" string="Loại" widget="badge" decoration-info="1"/>
                                    <field name="required" column_invisible="1"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="field_type" invisible="1"/>
                                            <div class="oe_title" colspan="2">
                                                <label for="label" string="Câu hỏi" style="font-weight: bold;"/>
                                                <h1><field name="label" readonly="1" nolabel="1"/></h1>
                                                <field name="placeholder" readonly="1" invisible="not placeholder" class="text-muted" nolabel="1"/>
                                            </div>
                                            
                                            <group string="Nhập câu trả lời">
                                                <field name="value_char" string="Trả lời" invisible="field_type != 'text'" required="required"/>
                                                <field name="value_text" string="Trả lời" widget="text" invisible="field_type != 'textarea'" required="required"/>
                                                <field name="value_float" string="Trả lời" invisible="field_type != 'number'" required="required"/>
                                                <field name="value_date" string="Trả lời" invisible="field_type != 'date'" required="required"/>
                                                
                                                <field name="date_ids" string="Chọn các ngày" invisible="field_type != 'date_multi'" required="required">
                                                    <list editable="bottom">
                                                        <field name="date"/>
                                                    </list>
                                                </field>

                                                <field name="value_boolean" string="Trả lời" widget="boolean_toggle" invisible="field_type != 'checkbox'"/>
                                                <field name="selected_option_ids" string="Trả lời" widget="many2many_tags" invisible="field_type not in ['select', 'select_multi']" required="required"/>
                                                <field name="required" invisible="1"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                            <field name="request_user_id"/>
                        </group>
                        <group string="Thông tin yêu cầu">
                            <field name="name" readonly="1"/>
                            <field name="request_user_name" readonly="1"/>
                            <field name="request_user_avatar" readonly="1" widget="image" options="{'size': [48, 48]}"/>
                            <field name="request_user_phone" string="Số điện thoại" readonly="1"/>
                            <field name="request_user_dormitory_full" string="Ký túc xá" readonly="1"/>
                            <field name="request_user_dormitory_room" readonly="1"/>
                            <field name="request_date" readonly="1"/>
                        </group>
                        <group string="Trạng thái duyệt">
                            <field name="final_state" readonly="1"/>
                            <field name="approve_content" readonly="1"/>
                            <field name="approve_date" readonly="1"/>
                            <field name="expired_date" readonly="(final_state == 'closed' or final_state == 'approved' or final_state == 'rejected')" help="Ngày hết hạn xử lý yêu cầu dịch vụ, sửa để gia hạn"/>
                            <field name="is_expired" readonly="1" invisible="1"/>
                            <field name="expiry_warning_sent" readonly="1" invisible="1"/>
                        </group>
                        <group string="Thông tin gia hạn" invisible="extension_count == 0">
                            <field name="extension_count" readonly="1"/>
                            <field name="total_extended_hours" readonly="1"/>
                        </group>
                         <group string="Thông tin người duyệt">
                            <field name="users" widget="many2many_tags" readonly="1"/>
                            <field name="role_ids" widget="many2many_tags" readonly="1"/>
                            <field name="approve_user_id" readonly="1"/>
                        </group>
                    </group>

                    <group invisible="(id == 0 or final_state == 'closed')" string="Các bước duyệt">
                        <field name="step_ids_active" widget="kanban" nolabel="1" no_create="true" options="{'no_create': true}">
                            <kanban>
                                <templates>
                                    <t t-name="kanban-box" t-if="!record.disabled.raw_value">
                                        <div class="card oe_kanban_card p-0" t-att-class="record.state.raw_value == 'rejected' ? 'bg-danger' : (record.state.raw_value == 'approved' ? 'bg-success' : (record.state.raw_value == 'pending' ? '' : 'bg-warning'))">
                                            <!-- field disabled để tính toán, không hiển thị -->
                                            <field name="disabled" invisible="1"/>
                                            <div class="card-header oe_kanban_header">
                                                <strong><field name="display_step_name"/></strong>
                                            </div>
                                            <div class="oe_kanban_details card-body">
                                                <div>
                                                    Trạng thái: 
                                                    <field name="status_id" invisible="not status_id"/>
                                                    <span invisible="status_id">
                                                        <field name="state"/>
                                                    </span>
                                                </div>
                                                <div>Nội dung duyệt: <field name="approve_content"/></div>
                                                <div>
                                                    <t t-if="record.base_secquence == 1 and record.request_id and record.request_id.service_id and record.request_id.service_id.files">
                                                        <div>
                                                            <strong>Files của dịch vụ:</strong>
                                                            <ul style="padding-left: 18px;">
                                                                <t t-foreach="record.request_id.service_id.files.raw_value" t-as="file">
                                                                    <li>
                                                                        <span t-esc="file.name"/>
                                                                        <span t-if="file.description"> (<t t-esc="file.description"/>)</span>
                                                                    </li>
                                                                </t>
                                                            </ul>
                                                        </div>
                                                        <div>
                                                            <field name="file_checkbox_ids" widget="many2many_tags"/>
                                                        </div>
                                                    </t>
                                                </div>
                                            </div>
                                            <div class="oe_kanban_footer card-body">
                                                <span>Người duyệt: <field name="assign_user_id" options="{'no_create': True}"/></span>
                                                <br/>
                                                <span>Lịch sử:</span>
                                                <field name="history_ids" readonly="1" nolabel="1"/>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </field>
                    </group>
                    <group invisible="(final_state != 'approved' and final_state != 'rejected' and final_state != 'closed')" string="Lịch sử nghiệm thu">
                        <field name="result_ids" widget="kanban" nolabel="1" no_create="true" options="{'no_create': true, 'no_open': true}">
                            <kanban>
                                <templates>
                                    <t t-name="kanban-box">
                                        <div class="card mb-2 p-0">
                                            <div class="card-header d-flex justify-content-between">
                                                <b><field name="action"/></b>
                                                <span class="badge">
                                                    <field name="star"/><i class="fa fa-star text-warning"></i> 
                                                </span>
                                            </div>
                                            <div class="card-body">
                                                <div><b>Nội dung:</b> <field name="note"/></div>
                                            </div>
                                            <div class="card-footer">
                                                <span class="text-muted">Người nghiệm thu: <field name="action_user" widget="many2one"/></span>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </field>
                    </group>
                    <group>
                        <group string="Đánh giá">
                            <field name="review_ids" />
                        </group>
                        <group string="Phản hồi">
                            <field name="complaint_ids" />
                        </group>
                    </group>
                    <group invisible="id != 0">
                        <button name="action_create_new" string="Tạo yêu cầu" type="object" class="btn-primary"/>
                <button name="action_back" string="Quay lại" type="object" class="btn-secondary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View danh sách yêu cầu dịch vụ -->
    <record id="view_service_request_kanban" model="ir.ui.view">
        <field name="name">student.service.request.kanban</field>
        <field name="model">student.service.request</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_view" default_order="id desc">
                <templates>
                    <t t-name="card">
                        <div class="card p-0" t-att-class="record.final_state.raw_value == 'rejected' ? 'bg-danger' : (record.final_state.raw_value == 'closed' ? 'bg-secondary disabled' : '')">
                            <div class="card-header oe_kanban_header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>
                                            <field name="service_id" options="{'no_create': True}"/>
                                        </strong>
                                        <div class="text-muted small">
                                            <i class="fa fa-hashtag"></i>
                                            Mã yêu cầu: <field name="id"/>
                                            <field name="has_unresolved_complaint" invisible="1"/>
                                            <field name="has_complaint" invisible="1"/>
                                            <t t-if="record.has_unresolved_complaint.raw_value">
                                                <span class="badge bg-danger ms-2" title="Có khiếu nại chưa giải quyết">
                                                    <i class="fa fa-flag"></i>
                                                    KN: <field name="unresolved_complaint_count"/>
                                                </span>
                                            </t>
                                            <t t-elif="record.has_complaint.raw_value">
                                                <span class="badge bg-warning text-dark ms-2" title="Có khiếu nại">
                                                    <i class="fa fa-flag"></i>
                                                    KN: <field name="complaint_count"/>
                                                </span>
                                            </t>
                                        </div>
                                    </div>
                                    <span class="badge ms-2" t-att-class="record.final_state.raw_value == 'closed' ? 'bg-secondary' : (record.final_state.raw_value == 'approved' ? 'bg-success' : (record.final_state.raw_value == 'rejected' ? 'bg-danger' : 'bg-warning'))">
                                        <field name="final_state"/>
                                    </span>
                                </div>
                            </div>
                            <div class="oe_kanban_details card-body">
                                <div class="d-flex flex-column align-items-center" style="margin-right: 10px; float: right;">
                                    <field name="request_user_avatar" widget="image" options="{'size': [64, 64]}"/>
                                    <b class="mt-2"><field name="request_user_name"/></b>
                                </div>
                                <div class="oe_kanban_title">
                                    <i><b><field name="note"/></b></i>
                                </div>

                                <div class="oe_kanban_date">
                                    <small>
                                        <i class="fa fa-calendar"></i>
                                        <field name="request_date" class="ms-2"/>
                                    </small>
                                </div>
                                <div class="oe_kanban_date">
                                    <small>
                                        <i class="fa fa-calendar"></i>
                                        <field name="expired_date" class="ms-2 text-warning"/>
                                    </small>
                                </div>
                                <div class="oe_kanban_note">
                                    <small>
                                        <i class="fa fa-sticky-note"></i>
                                        <field name="approve_content" class="ms-2"/>
                                    </small>
                                </div>
                                                                <div class="oe_kanban_date">
                                    <small>
                                        <i class="fa fa-tasks"></i>
                                        <strong class="ms-2 text-primary">
                                            <field name="current_step_name"/>
                                        </strong>
                                    </small>
                                </div>
                                <div class="oe_kanban_note">
                                    <small>
                                        <i class="fa fa-archive"></i>
                                        <field name="final_state" class="ms-2 bold"/>
                                    </small>
                                </div>
                                    <div class="oe_kanban_images">
                                    <small>
                                        <div class="mt-1">
                                            <div class="mb-1">
                                                <strong>Người duyệt:</strong> <field name="users" widget="many2many_tags" options="{'no_create': true, 'no_open': true}"/>
                                            </div>
                                            <div>
                                                <strong>Vai trò:</strong> <field name="role_ids" widget="many2many_tags" options="{'no_create': true, 'no_open': true}"/>
                                            </div>
                                        </div>
                                    </small>
                                </div>
                                <div class="oe_kanban_images">
                                    <b><i> Người xử lý: </i></b>
                                    <field class="badge bg-secondary" name="user_processing_id"/>
                                </div>
                            </div>
                            <t t-if="record.final_state.raw_value == 'approved'">
                                <div class="card-footer">
                                    <button name="%(action_open_temporary_wizard)d" string="Nghiệm thu" type="action" t-att-context="{'default_request_id': record.id.raw_value}" class="btn-primary"/>
                                    <div class="badge">
                                        <t t-if="record.result_ids">
                                            <i class="fa fa-history" title='Đã có nghiệm thu từ Sinh viên'></i>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_student_service_request_list" model="ir.ui.view">
        <field name="name">student.service.request.list</field>
        <field name="model">student.service.request</field>
        <field name="arch" type="xml">
            <list decoration-danger="has_unresolved_complaint" decoration-warning="has_complaint">
               <field name="id"/>
               <field name="service_id"/>
               <field name="request_user_id"/>
               <field name="final_state"/>
               <field name="request_date"/>
               <field name="note"/>
               <field name="complaint_count" string="KN"/>
               <field name="unresolved_complaint_count" string="KN chưa giải quyết"/>
               <field name="users" />
               <field name="role_ids"/>
               <field name="approve_user_id"/>
            </list>
        </field>
    </record>
    <record id="view_student_service_request_search" model="ir.ui.view">
        <field name="name">student.service.request.search</field>
        <field name="model">student.service.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="service_id"/>
                <field name="note"/>
                <field name="request_user_id"/>

                <filter string="Đã duyệt" name="approved" domain="[('final_state','=','approved')]"/>
                <filter string="Chưa duyệt" name="not_approved" domain="[('final_state','!=','approved')]"/>
                <filter string="Có khiếu nại" name="has_complaint" domain="[('has_complaint','=',True)]"/>
                <filter string="KN chưa giải quyết" name="has_unresolved_complaint" domain="[('has_unresolved_complaint','=',True)]"/>
            </search>
        </field>
    </record>
    <!-- Action mở form tạo yêu cầu dịch vụ -->
    <record id="action_service_request" model="ir.actions.act_window">
        <field name="name">Yêu cầu dịch vụ</field>
        <field name="res_model">student.service.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_student_service_request_search"/>
    </record>
    
    <record id="view_student_service_request_step_history_tree" model="ir.ui.view">
        <field name="name">student.service.request.step.history.tree</field>
        <field name="model">student.service.request.step.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="state"/>
                <field name="user_id"/>
                <field name="note"/>
                <field name="date"/>
            </list>
        </field>
    </record>
    <!-- Duyệt yêu cầu dịch vụ -->
    <record id="view_student_service_request_step_form" model="ir.ui.view">
        <field name="name">student.service.request.step.form</field>
        <field name="model">student.service.request.step</field>
        <field name="arch" type="xml">
            <form string="Bước duyệt yêu cầu dịch vụ">
                <header>
                    <button name="action_back" string="Quay lại" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Thông tin yêu cầu dịch vụ">
                            <field name="request_id" readonly="1"/>
                            <field name="display_step_name" readonly="1"/>
                        </group>
                        <group string="Các bước duyệt (theo dịch vụ)">
                            <field name="step_selection_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                        <group string="Thông tin duyệt">
                            <field name="available_status_ids" invisible="1"/>
                            <field name="status_id" options="{'no_create': True}" domain="[('id', 'in', available_status_ids)]"/>
                            <field name="state" readonly="1" force_save="1"/>
                            <field name="approve_content"/>
                            <field name="assign_user_id" domain="[('id', 'in', allowed_user_ids)]"/> 
                            <field name="department_id" />
                        </group>
                        <group string="Nghiệm thu">
                            <field name="final_data" readonly="base_secquence != 99"/>
                        </group>
                        <group string="Thông tin đính kèm">
                            <field name="file_ids" widget="many2many_tags" readonly="1" invisible="base_secquence != 1" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="file_checkbox_ids" widget="many2many_checkboxes" invisible="base_secquence != 1" domain="[('id','in', file_ids)]"/>
                        </group>
                        <group string="Lịch sử duyệt">
                            <field name="history_ids" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_confirm_approve" string="Xác nhận duyệt" type="object" class="btn-primary" confirm="Bạn có chắc chắn muốn xác nhận duyệt bước này không?"/>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Cron job check request timeout -->
    <record id="cron_check_request_timeout" model="ir.cron">
        <field name="name">Check Request Timeout</field>
        <field name="model_id" ref="model_student_service_request"/> 
        <field name="state">code</field>
        <field name="code">model.cron_check_timeout_requests()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_admin"/>
    </record>

    <record id="action_student_service_request_step" model="ir.actions.act_window">
        <field name="name">Bước duyệt yêu cầu dịch vụ</field>
        <field name="res_model">student.service.request.step</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- NEW: Completely new student request form (no inheritance) -->
    <record id="view_student_service_request_form_new" model="ir.ui.view">
        <field name="name">student.service.request.form.new</field>
        <field name="model">student.service.request</field>
        <field name="arch" type="xml">
            <form string="Tạo yêu cầu dịch vụ (Mới)" create="true" delete="false" edit="true">
                <sheet>
                    <group string="Thông tin yêu cầu">
                        <field name="service_id" required="1" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="note" placeholder="Mô tả thêm về yêu cầu của bạn"/>
                        <field name="image_attachment_ids" widget="many2many_binary" string="Ảnh đính kèm"/>
                        <!-- Hidden helper field so the domain can read computed values -->
                        <field name="student_user_ids" invisible="1"/>
                                             <!-- Allow all users to select a student sender. Use context variable for group reference -->
                        <field name="request_user_id" string="Sinh viên gửi" domain="[('groups_id', 'in', [context.get('student_req_group_id')])]" options="{'no_create': True, 'no_create_edit': True}"/>
                        
                        <!-- Dynamic Input Table -->
                        <field name="input_ids" nolabel="1" colspan="2" invisible="not service_id">
                            <list>
                                <field name="sequence" widget="handle"/>
                                <field name="label"/>   
                                <field name="field_type"/>
                                <field name="value_display" string="Giá trị"/>
                            </list>
                            <form>
                                <group>
                                    <field name="label" readonly="1"/>
                                    <field name="field_type" invisible="1"/>
                                    <field name="required" invisible="1"/>
                                    
                                    <!-- Show only relevant value field based on field_type -->
                                    <field name="value_char" string="Giá trị" invisible="field_type not in ['text']"/>
                                    <field name="value_text" string="Giá trị" widget="text" invisible="field_type not in ['textarea']"/>
                                    <field name="value_float" string="Giá trị" invisible="field_type not in ['number']"/>
                                    <field name="value_date" string="Giá trị" invisible="field_type not in ['date']"/>
                                    <field name="value_boolean" string="Giá trị" invisible="field_type not in ['checkbox']"/>
                                    <field name="value_selection" string="Giá trị" invisible="field_type not in ['select']"/>
                                </group>
                            </form>
                        </field>
                    </group>
                    <group invisible="id != 0">
                        <button name="action_create_new" string="Gửi yêu cầu" type="object" class="btn-primary"/>
                        <button name="action_back" string="Quay lại" type="object" class="btn-secondary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_service_request_create_new" model="ir.actions.act_window">
        <field name="name">Tạo yêu cầu (Mới)</field>
        <field name="res_model">student.service.request</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_student_service_request_form_new"/>
        <!-- Mở form với trường 'Sinh viên gửi' để trống, admin sẽ chọn sinh viên cần gửi hộ -->
        <field name="context" eval="{'default_request_user_id': False, 'student_req_group_id': ref('student_request.group_student_request_user') }"/>
    </record>

</odoo>
