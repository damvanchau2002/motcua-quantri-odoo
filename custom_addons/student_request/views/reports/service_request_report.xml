<odoo>
    <record id="view_service_request_report_tree" model="ir.ui.view">
        <field name="name">service.request.report.tree</field>
        <field name="model">service.request.report</field>
        <field name="arch" type="xml">
            <list string="Báo cáo tổng hợp yêu cầu dịch vụ">
                <field name="report_date"/>
                <field name="cluster"/>
                <field name="house"/>
                <field name="service_group"/>
                <field name="service_name"/>
                <field name="total_request"/>
                <field name="processed"/>
                <field name="unprocessed"/>
                <field name="overdue"/>
                <field name="percent_processed"/>
            </list>
        </field>
    </record>
</odoo>


<record id="action_service_request_report" model="ir.actions.act_window">
    <field name="name">Báo cáo tổng hợp yêu cầu dịch vụ</field>
    <field name="res_model">service.request.report</field>
    <field name="view_mode">list</field>
    <field name="target">current</field>
</record>