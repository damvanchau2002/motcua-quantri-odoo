<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_service_request_state_tree" model="ir.ui.view">
        <field name="name">student.service.request.state.tree</field>
        <field name="model">student.service.request.state</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="type"/>
                <field name="color" widget="color_picker"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_student_service_request_state_form" model="ir.ui.view">
        <field name="name">student.service.request.state.form</field>
        <field name="model">student.service.request.state</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Mô tả..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_service_request_state" model="ir.actions.act_window">
        <field name="name">Trạng thái xử lý</field>
        <field name="res_model">student.service.request.state</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>