<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_activity_role_list" model="ir.ui.view">
        <field name="name">student.activity.role.list</field>
        <field name="model">student.activity.role</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="level"/>
            </list>
        </field>
    </record>

    <record id="view_student_activity_role_form" model="ir.ui.view">
        <field name="name">student.activity.role.form</field>
        <field name="model">student.activity.role</field>
        <field name="arch" type="xml">
            <form string="Vai trò hoạt động">
                <header>
                    <button name="action_back" string="Quay lại" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="level"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_activity_role" model="ir.actions.act_window">
        <field name="name">Student Activity Roles</field>
        <field name="res_model">student.activity.role</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>