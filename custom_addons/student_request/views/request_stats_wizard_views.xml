<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard form with summary cards and actions -->
    <record id="view_student_request_stats_wizard_form" model="ir.ui.view">
        <field name="name">student.request.stats.wizard.form</field>
        <field name="model">student.request.stats.wizard</field>
        <field name="arch" type="xml">
            <form string="Bảng thống kê yêu cầu">
                <header>
                    <button name="action_open_status_graph" type="object" string="Xem biểu đồ trạng thái" class="btn-primary"/>
                    <button name="action_open_visits_graph" type="object" string="Xem biểu đồ truy cập" class="btn-secondary"/>
                </header>
                <sheet>
                    <group string="Bộ lọc">
                        <field name="period"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Tổng hợp" colspan="2">
                        <group>
                            <field name="total_requests" readonly="1"/>
                            <field name="processing_requests" readonly="1"/>
                        </group>
                        <group>
                            <field name="overdue_requests" readonly="1"/>
                            <field name="near_overdue_requests" readonly="1"/>
                        </group>
                        <group>
                            <field name="avg_daily_users" readonly="1"/>
                            <field name="avg_requests_per_day" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_request_stats_wizard" model="ir.actions.act_window">
        <field name="name">Bảng thống kê yêu cầu</field>
        <field name="res_model">student.request.stats.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Menu: open wizard -->
    <menuitem id="menu_student_request_dashboard_wizard" name="Bảng thống kê" parent="student_request_root" action="action_student_request_stats_wizard" sequence="90"/>
</odoo>