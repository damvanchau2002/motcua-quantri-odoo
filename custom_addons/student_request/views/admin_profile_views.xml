<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cấu hình tài khoản duyệt -->
    <record id="view_student_admin_profile_list" model="ir.ui.view">
        <field name="name">student.admin.profile.list</field>
        <field name="model">student.admin.profile</field>
        <field name="arch" type="xml">
            <list editable="bottom" create="false" delete="false">
                <field name="user_id"/>
                <field name="title_name"/>
                <field name="activated" widget="boolean_toggle"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="dormitory_area_id"/>
                <field name="dormitory_clusters"  widget="many2many_tags"/>
                <field name="department_id" />
                <field name="role_ids" widget="many2many_tags" />
                <!-- Hiển thị chuyên môn trong danh sách -->
                <field name="specialization"/>
            </list>
        </field>
    </record>
    <record id="view_student_admin_profile_form" model="ir.ui.view">
        <field name="name">student.admin.profile.form</field>
        <field name="model">student.admin.profile</field>
        <field name="arch" type="xml">
            <form string="Thông tin quản trị viên">
                <header>
                    <button name="action_back" string="Quay lại" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group string="Thông tin">
                        <field name="user_id" readonly="id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <!-- required tiêu đề tài khoản -->
                        <field name="title_name" required="1"/>
                        <!-- yêu cầu chọn khu và cụm, cụm lọc theo khu -->
                        <field name="dormitory_area_id" required="1"/>
                        <field name="dormitory_clusters" domain="[('area_id','=',dormitory_area_id)]" required="1"/>
                        <!-- yêu cầu chọn vai trò và phòng ban; phòng ban lọc theo cụm đã chọn -->
                        <field name="role_ids" widget="many2many_tags" options="{'no_create': True, 'no_create_edit': True}" required="1"/>
                        <field name="department_id" domain="[('cluster_ids','in', dormitory_clusters)]" required="1"/>
                        <field name="specialization" />
                        <field name="activated"/>
                    </group>
                    <group string="Thông tin người dùng">
                        <field name="phone" widget="phone"/>
                        <field name="email" widget="email" required="1"/>
                        <field name="birthday"/>
                        <field name="fcm_token"/>
                        <field name="device_id"/>
                    </group>
                    <group string="Các provider đăng nhập">
                        <field name="oauth_ids" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_admin_manager_user" model="ir.actions.act_window">
        <field name="name">Admin Manager Users</field>
        <field name="res_model">student.admin.profile</field>
        <field name="view_mode">list,form</field>
    </record>
    <!-- Admin.OAuth -->
    <record id="view_student_admin_oauth_list" model="ir.ui.view">
        <field name="name">student.admin.oauth.list</field>
        <field name="model">student.admin.oauth</field>
        <field name="arch" type="xml">
            <list>
                <field name="profile_id"/>
                <field name="provider"/>
                <field name="token"/>
                <field name="avatar_url"/>
            </list>
        </field>
    </record>
    <record id="view_student_admin_oauth_form" model="ir.ui.view">
        <field name="name">student.admin.oauth.form</field>
        <field name="model">student.admin.oauth</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Thông tin OAuth">
                        <field name="provider" required="1"/>
                        <field name="avatar_url" widget="url" />
                        <field name="token" required="1"/>
                        <field name="profile_id" required="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_admin_oauth" model="ir.actions.act_window">
        <field name="name">Admin OAuth</field>
        <field name="res_model">student.admin.oauth</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
