<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Tree view for request.extension -->
        <record id="view_request_extension_tree" model="ir.ui.view">
            <field name="name">request.extension.tree</field>
            <field name="model">request.extension</field>
            <field name="arch" type="xml">
                <list string="Lịch sử gia hạn" decoration-success="state=='approved'" decoration-danger="state=='rejected'" decoration-info="state=='submitted'">
                    <field name="name"/>
                    <field name="request_id"/>
                    <field name="hours"/>
                    <field name="reason"/>
                    <field name="requested_by"/>
                    <field name="state"/>
                    <field name="create_date"/>
                    <field name="approved_by"/>
                    <field name="approval_date"/>
                </list>
            </field>
        </record>

        <!-- Form view cho request.extension -->
        <record id="view_request_extension_form" model="ir.ui.view">
            <field name="name">request.extension.form</field>
            <field name="model">request.extension</field>
            <field name="arch" type="xml">
                <form string="Yêu cầu gia hạn">
                    <header>
                        <button name="action_submit" type="object" string="Gửi yêu cầu" 
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve" type="object" string="Duyệt" 
                                class="btn-success" invisible="state != 'submitted'"
                                groups="student_request.group_student_request_manager"/>
                        <button name="action_reject" type="object" string="Từ chối" 
                                class="btn-danger" invisible="state != 'submitted'"
                                groups="student_request.group_student_request_manager"/>
                        <button name="action_reset_to_draft" type="object" string="Đặt lại nháp" 
                                invisible="state == 'draft'"
                                groups="student_request.group_student_request_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        
                        <group>
                            <group string="Thông tin yêu cầu">
                                <field name="request_id" readonly="state != 'draft'" 
                                       domain="[('final_state', 'in', ['processing', 'pending', 'in_progress']), ('expired_date', '>', context_today())]"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="hours" readonly="state != 'draft'"/>
                                <field name="reason" readonly="state != 'draft'"/>
                            </group>
                            <group string="Thông tin người yêu cầu">
                                <field name="requested_by" readonly="1"/>
                                <field name="request_date" readonly="1"/>
                            </group>
                        </group>
                        
                        <group>
                            <group string="Thông tin deadline">
                                <field name="original_deadline" readonly="1"/>
                                <field name="new_deadline" readonly="1"/>
                            </group>
                            <group string="Thông tin duyệt" invisible="state in ['draft', 'submitted']">
                                <field name="approved_by" readonly="1"/>
                                <field name="approval_date" readonly="1"/>
                                <field name="rejection_reason" readonly="1" invisible="state != 'rejected'"/>
                            </group>
                        </group>
                        
                        <group string="Thống kê gia hạn">
                            <group>
                                <field name="total_extensions" readonly="1"/>
                                <field name="total_extended_hours" readonly="1"/>
                            </group>
                        </group>
                </sheet>
            </form>
            </field>
        </record>

        <!-- Action cho request.extension -->
        <record id="action_request_extension" model="ir.actions.act_window">
            <field name="name">Yêu cầu gia hạn</field>
            <field name="res_model">request.extension</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_state': 'draft'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo yêu cầu gia hạn đầu tiên
                </p>
                <p>
                    Nhấn "Tạo" để tạo yêu cầu gia hạn mới cho các dịch vụ đang xử lý.
                </p>
            </field>
        </record>

        <!-- Action for pending extensions -->
        <record id="action_request_extension_pending" model="ir.actions.act_window">
            <field name="name">Chờ duyệt gia hạn</field>
            <field name="res_model">request.extension</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'submitted')]</field>
            <field name="context">{'default_state': 'submitted'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Không có yêu cầu gia hạn nào đang chờ duyệt
                </p>
            </field>
        </record>

        <!-- Action for approved extensions -->
        <record id="action_request_extension_approved" model="ir.actions.act_window">
            <field name="name">Đã duyệt gia hạn</field>
            <field name="res_model">request.extension</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'approved')]</field>
            <field name="context">{'default_state': 'approved'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Không có yêu cầu gia hạn nào đã được duyệt
                </p>
            </field>
        </record>

        <!-- Wizard form view -->
        <record id="view_request_extension_wizard_form" model="ir.ui.view">
            <field name="name">request.extension.wizard.form</field>
            <field name="model">request.extension.wizard</field>
            <field name="arch" type="xml">
                <form string="Yêu cầu gia hạn">
                    <sheet>
                        <div class="oe_title">
                            <h1>Yêu cầu gia hạn thời gian</h1>
                        </div>
                        
                        <group>
                            <group string="Thông tin yêu cầu hiện tại">
                                <field name="request_id" readonly="1"/>
                                <field name="current_deadline" readonly="1"/>
                                <field name="current_status" readonly="1"/>
                            </group>
                            <group string="Thông tin gia hạn hiện có">
                                <field name="current_extensions" readonly="1"/>
                                <field name="current_extended_hours" readonly="1"/>
                                <field name="remaining_hours_allowed" readonly="1"/>
                            </group>
                        </group>
                        
                        <group>
                            <group string="Yêu cầu gia hạn mới">
                                <field name="hours" required="1"/>
                                <field name="reason" required="1"/>
                            </group>
                            <group string="Thông tin tính toán">
                                <field name="new_deadline" readonly="1"/>
                            </group>
                        </group>
                        
                        <div class="alert alert-info" role="alert">
                            <strong>Lưu ý:</strong>
                            <ul>
                                <li>Mỗi lần gia hạn tối đa 720 giờ (30 ngày)</li>
                                <li>Tổng thời gian gia hạn không quá 2160 giờ (90 ngày)</li>
                                <li>Phải có lý do cụ thể cho việc gia hạn</li>
                            </ul>
                        </div>
                    </sheet>
                    
                    <footer>
                        <button name="action_submit_extension" type="object" string="Gửi yêu cầu" class="btn-primary"/>
                        <button string="Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Wizard cho từ chối gia hạn -->
        <record id="view_request_extension_reject_wizard_form" model="ir.ui.view">
            <field name="name">request.extension.reject.wizard.form</field>
            <field name="model">request.extension.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Từ chối yêu cầu gia hạn">
                    <sheet>
                        <div class="oe_title">
                            <h1>Từ chối yêu cầu gia hạn</h1>
                        </div>
                        
                        <group>
                            <field name="extension_id" readonly="1"/>
                            <field name="rejection_reason" required="1" placeholder="Nhập lý do từ chối..."/>
                        </group>
                        
                        <div class="alert alert-warning" role="alert">
                            <strong>Cảnh báo:</strong> Việc từ chối yêu cầu gia hạn sẽ không thay đổi deadline hiện tại. 
                            Người yêu cầu sẽ nhận được thông báo về lý do từ chối.
                        </div>
                    </sheet>
                    
                    <footer>
                        <button name="action_reject_extension" type="object" string="Xác nhận từ chối" class="btn-danger"/>
                        <button string="Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>