<odoo>
    <record id="view_student_email_template_list" model="ir.ui.view">
        <field name="name">student.email.template.list</field>
        <field name="model">student.email.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject"/>
                <field name="email_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_student_email_template_form" model="ir.ui.view">
        <field name="name">student.email.template.form</field>
        <field name="model">student.email.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="subject"/>
                        <field name="email_to"/>
                        <field name="body_html" widget="html"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_email_template" model="ir.actions.act_window">
        <field name="name">Student Email Templates</field>
        <field name="res_model">student.email.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_student_email_template"
              name="Student Email Templates"
              parent="base.menu_custom"
              action="action_student_email_template"/>
</odoo>