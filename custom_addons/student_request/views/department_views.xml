<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View for student.activity.department -->
    <record id="view_student_activity_department_list" model="ir.ui.view">
        <field name="name">student.activity.department.list</field>
        <field name="model">student.activity.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="cluster_ids"/>
            </list>
        </field>
    </record>

    <!-- Form View for student.activity.department -->
    <record id="view_student_activity_department_form" model="ir.ui.view">
        <field name="name">student.activity.department.form</field>
        <field name="model">student.activity.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="cluster_ids" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action Window for student.activity.department -->
    <record id="action_student_activity_department" model="ir.actions.act_window">
        <field name="name">Phòng ban</field>
        <field name="res_model">student.activity.department</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

