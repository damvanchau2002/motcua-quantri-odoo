<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- === FIELD TEMPLATE === -->
    <record id="view_field_template_list" model="ir.ui.view">
        <field name="name">student.service.field.template.list</field>
        <field name="model">student.service.field.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="label"/>
                <field name="field_type_suggestion"/>
                <field name="placeholder" optional="hide"/>
                <field name="required"/>
                <field name="options" optional="hide"/>
                <field name="description" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_field_template_form" model="ir.ui.view">
        <field name="name">student.service.field.template.form</field>
        <field name="model">student.service.field.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="VD: student_id, full_name, phone"/>
                            <field name="label" placeholder="VD: Mã sinh viên, Họ và tên"/>
                            <field name="field_type_suggestion"/>
                            <field name="placeholder" placeholder="VD: Nhập mã sinh viên..."/>
                        </group>
                        <group>
                            <field name="required"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Mô tả chi tiết về field này..."/>
                    </group>
                    <group string="Options (cho Dropdown)">
                        <field name="options" placeholder="Option 1&#10;Option 2&#10;Option 3" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_field_template" model="ir.actions.act_window">
        <field name="name">Field Templates</field>
        <field name="res_model">student.service.field.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo template field mới
            </p>
            <p>
                Các template này sẽ được dùng làm dropdown khi tạo form fields cho dịch vụ.
            </p>
        </field>
    </record>

    <menuitem 
        id="menu_field_template" 
        name="Field Templates" 
        parent="student_request_config"
        action="action_field_template"
        sequence="15"/>

</odoo>
