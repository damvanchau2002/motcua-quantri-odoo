<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Server Actions - Định nghĩa trước để tránh lỗi tham chiếu -->
    <record id="action_toggle_maintenance" model="ir.actions.server">
        <field name="name">Bật/Tắt bảo trì</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
current_status = env['ir.config_parameter'].sudo().get_param('maintenance.status', 'off')
if current_status == 'on':
    env['ir.config_parameter'].sudo().set_param('maintenance.status', 'off')
    env['ir.config_parameter'].sudo().set_param('maintenance.end_time', datetime.datetime.now().isoformat())
    title = '🟢 Đã tắt bảo trì'
    message = 'Hệ thống đã hoạt động bình thường'
    notification_type = 'success'
else:
    env['ir.config_parameter'].sudo().set_param('maintenance.status', 'on')
    env['ir.config_parameter'].sudo().set_param('maintenance.start_time', datetime.datetime.now().isoformat())
    title = '🔴 Đã bật bảo trì'
    message = 'Hệ thống đã chuyển sang chế độ bảo trì'
    notification_type = 'warning'

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_maintenance_on" model="ir.actions.server">
        <field name="name">Bật bảo trì</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.status', 'on')
env['ir.config_parameter'].sudo().set_param('maintenance.start_time', datetime.datetime.now().isoformat())

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_maintenance_off" model="ir.actions.server">
        <field name="name">Tắt bảo trì</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.status', 'off')
env['ir.config_parameter'].sudo().set_param('maintenance.end_time', datetime.datetime.now().isoformat())

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <!-- Duration Actions -->
    <record id="action_set_duration_30min" model="ir.actions.server">
        <field name="name">Cài đặt bảo trì 30 phút</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.duration', '30 phút')
env['ir.config_parameter'].sudo().set_param('maintenance.status', 'on')
base = datetime.datetime.now()
env['ir.config_parameter'].sudo().set_param('maintenance.start_time', base.isoformat())
end_time = base + datetime.timedelta(minutes=30)
env['ir.config_parameter'].sudo().set_param('maintenance.end_time', end_time.isoformat())

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_duration_1hour" model="ir.actions.server">
        <field name="name">Cài đặt bảo trì 1 giờ</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.duration', '1 giờ')
env['ir.config_parameter'].sudo().set_param('maintenance.status', 'on')
base = datetime.datetime.now()
env['ir.config_parameter'].sudo().set_param('maintenance.start_time', base.isoformat())
end_time = base + datetime.timedelta(hours=1)
env['ir.config_parameter'].sudo().set_param('maintenance.end_time', end_time.isoformat())

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_duration_2hour" model="ir.actions.server">
        <field name="name">Cài đặt bảo trì 2 giờ</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.duration', '2 giờ')
env['ir.config_parameter'].sudo().set_param('maintenance.status', 'on')
base = datetime.datetime.now()
env['ir.config_parameter'].sudo().set_param('maintenance.start_time', base.isoformat())
end_time = base + datetime.timedelta(hours=2)
env['ir.config_parameter'].sudo().set_param('maintenance.end_time', end_time.isoformat())

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <!-- Message Actions -->
    <record id="action_set_message_update" model="ir.actions.server">
        <field name="name">Thông báo cập nhật</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.message', 'Hệ thống đang cập nhật, vui lòng quay lại sau')

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_message_maintenance" model="ir.actions.server">
        <field name="name">Thông báo bảo trì</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.message', 'Hệ thống đang bảo trì định kỳ')

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_message_upgrade" model="ir.actions.server">
        <field name="name">Thông báo nâng cấp</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
env['ir.config_parameter'].sudo().set_param('maintenance.message', 'Đang nâng cấp hệ thống, xin lỗi vì sự bất tiện')

action = {
    'type': 'ir.actions.client',
    'tag': 'reload',
}
        </field>
    </record>

    <record id="action_set_custom_message" model="ir.actions.server">
        <field name="name">Tùy chỉnh thông báo</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Tùy chỉnh thông báo bảo trì',
    'res_model': 'maintenance.message.wizard',
    'view_mode': 'form',
    'target': 'new',
}
        </field>
    </record>

    <!-- Model để quản lý maintenance dễ dàng hơn -->
    <record id="view_maintenance_dashboard_form" model="ir.ui.view">
        <field name="name">maintenance.dashboard.form</field>
        <field name="model">maintenance.dashboard</field>
        <field name="arch" type="xml">
            <form string="Quản lý bảo trì hệ thống" create="false" edit="false" delete="false">
                <header>
                    <div class="btn-toolbar" role="toolbar">
                        <div class="btn-group me-2" role="group">
                            <button name="%(action_toggle_maintenance)d" 
                                    string="🔄 Bật/Tắt bảo trì" 
                                    type="action" 
                                    class="btn-primary"/>
                            <button name="%(action_set_maintenance_on)d" 
                                    string="🔴 Bật bảo trì" 
                                    type="action" 
                                    class="btn-outline-warning"/>
                            <button name="%(action_set_maintenance_off)d" 
                                    string="🟢 Tắt bảo trì" 
                                    type="action" 
                                    class="btn-outline-success"/>
                        </div>
                        <div class="btn-group" role="group">
                            <button name="%(action_set_custom_message)d" 
                                    string="✏️ Tùy chỉnh thông báo" 
                                    type="action" 
                                    class="btn-outline-secondary"/>
                        </div>
                    </div>
                </header>
                <sheet>
                    <div class="container-fluid py-2">
                        <div class="oe_title text-center mb-3">
                            <h1 class="display-6">🛠️ Bảng điều khiển bảo trì</h1>
                            <p class="text-muted">Quản lý trạng thái hệ thống, thời lượng và thông báo một cách nhanh chóng</p>
                        </div>

                        <div class="row g-3">
                            <!-- Status card -->
                            <div class="col-lg-6">
                                <div class="card shadow-sm">
                                    <div class="card-header d-flex align-items-center justify-content-between">
                                        <h3 class="h5 mb-0">📊 Trạng thái hiện tại</h3>
                                        <span class="badge bg-info">Live</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="alert alert-light border">
                                            <field name="status_text" class="h4 mb-2" readonly="1" nolabel="1"/>
                                            <field name="message_text" class="mb-1" readonly="1" nolabel="1"/>
                                            <field name="updated_text" class="text-muted" readonly="1" nolabel="1"/>
                                            <hr/>
                                            <div class="small">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="text-muted">⏱ Thời lượng dự kiến</span>
                                                    <field name="maintenance_duration" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="text-muted">🟡 Bắt đầu</span>
                                                    <field name="maintenance_start_time" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <span class="text-muted">🔵 Kết thúc dự kiến</span>
                                                    <field name="maintenance_end_time" readonly="1" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Quick settings card -->
                            <div class="col-lg-6">
                                <div class="card shadow-sm">
                                    <div class="card-header">
                                        <h3 class="h5 mb-0">⚙️ Cài đặt nhanh</h3>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-grid gap-2">
                                            <button name="%(action_set_duration_30min)d" 
                                                    string="⏰ Bảo trì 30 phút" 
                                                    type="action" 
                                                    class="btn btn-outline-primary"/>
                                            <button name="%(action_set_duration_1hour)d" 
                                                    string="⏰ Bảo trì 1 giờ" 
                                                    type="action" 
                                                    class="btn btn-outline-primary"/>
                                            <button name="%(action_set_duration_2hour)d" 
                                                    string="⏰ Bảo trì 2 giờ" 
                                                    type="action" 
                                                    class="btn btn-outline-primary"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Preset messages -->
                        <div class="row g-3 mt-1">
                            <div class="col-12">
                                <div class="card shadow-sm">
                                    <div class="card-header">
                                        <h3 class="h5 mb-0">📝 Thông báo mẫu</h3>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-grid gap-2">
                                            <button name="%(action_set_message_update)d" 
                                                    string="🔄 Hệ thống đang cập nhật, vui lòng quay lại sau" 
                                                    type="action" 
                                                    class="btn btn-outline-info"/>
                                            <button name="%(action_set_message_maintenance)d" 
                                                    string="🛠️ Hệ thống đang bảo trì định kỳ" 
                                                    type="action" 
                                                    class="btn btn-outline-info"/>
                                            <button name="%(action_set_message_upgrade)d" 
                                                    string="⬆️ Đang nâng cấp hệ thống, xin lỗi vì sự bất tiện" 
                                                    type="action" 
                                                    class="btn btn-outline-info"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>



    <!-- Action cho dashboard -->
    <record id="action_maintenance_dashboard" model="ir.actions.act_window">
        <field name="name">🛠️ Bảng điều khiển bảo trì</field>
        <field name="res_model">maintenance.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_maintenance_dashboard_form"/>
        <field name="target">current</field>
        <!-- Dashboard không gắn với ir.config_parameter để tránh tự tạo bản ghi -->
    </record>

    <!-- Server Action mở dashboard và tạo bản ghi để đảm bảo computed fields có dữ liệu -->
    <record id="action_open_maintenance_dashboard" model="ir.actions.server">
        <field name="name">Mở bảng điều khiển bảo trì</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">
wizard = env['maintenance.dashboard'].create({})
action = {
    'type': 'ir.actions.act_window',
    'name': '🛠️ Bảng điều khiển bảo trì',
    'res_model': 'maintenance.dashboard',
    'view_mode': 'form',
    'views': [(env.ref('student_request.view_maintenance_dashboard_form').id, 'form')],
    'res_id': wizard.id,
    'target': 'current',
}
        </field>
    </record>

    <!-- Wizard chỉnh sửa thông báo bảo trì -->
    <record id="view_maintenance_message_wizard_form" model="ir.ui.view">
        <field name="name">maintenance.message.wizard.form</field>
        <field name="model">maintenance.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Tùy chỉnh thông báo bảo trì" create="false" edit="false">
                <sheet>
                    <group>
                        <field name="message" string="Thông báo"/> 
                    </group>
                </sheet>
                <footer>
                    <button name="action_save" string="Lưu" type="object" class="btn-primary"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>