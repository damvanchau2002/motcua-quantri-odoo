<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cấu hình tài khoản duyệt -->
    <record id="view_student_manage_admin_list" model="ir.ui.view">
        <field name="name">student.user.profile.list</field>
        <field name="model">student.user.profile</field>
        <field name="arch" type="xml">
            <list string="Quản lý sinh viên KTX">
                <field name="user_id"/>
                <field name="dormitory_full_name"/>
                <field name="university_name"/>
                <field name="student_code"/>
                <field name="id_card_number"/>
                <field name="dormitory_house_name"/>
                <field name="dormitory_room_type_name"/>
            </list>
        </field>
    </record>

    <record id="view_student_manage_admin_form" model="ir.ui.view">
        <field name="name">student.user.profile.form</field>
        <field name="model">student.user.profile</field>
        <field name="arch" type="xml">
            <form string="Thông tin sinh viên">
                <header>
                    <!-- Nút quay lại chỉ hiện khi đã có bản ghi -->
                    <button name="action_back" string="Quay lại" type="object" class="btn-secondary"
                            modifiers='{"invisible": [["id", "=", false]]}'/>
                </header>
                <sheet>
                    <group string="Thông tin">
                        <!-- Khi tạo mới: chỉ hiển thị trường CCCD -->
                        <group invisible="student_code">
                            <field name="user_id" readonly="1" invisible="True"/>
                            <field name="id_card_number" placeholder="Nhập số CCCD" required="1"/>
                        </group>

                        <!-- Khi đã có record -->
                        <group invisible="not student_code">
                            <field name="user_id" readonly="1"/>
                            <field name="dormitory_full_name" readonly="1"/>
                            <field name="university_name" readonly="1"/>
                            <field name="student_code" readonly="1"/>
                            <field name="id_card_number" readonly="1"/>
                            <field name="dormitory_house_name" readonly="1"/>
                            <field name="dormitory_room_type_name" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_manage_admin_menu" model="ir.actions.act_window">
        <field name="name">Quản lý sinh viên KTX</field>
        <field name="res_model">student.user.profile</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
