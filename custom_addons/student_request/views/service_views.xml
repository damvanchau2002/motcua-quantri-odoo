<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- === SERVICE === -->
    <record id="view_student_service_list" model="ir.ui.view">
        <field name="name">student.service.list</field>
        <field name="model">student.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="state"/>
                <field name="group_id"/>
                <field name="duration"/>
                <field name="files" widget="many2many_tags"/>
                <field name="users" widget="many2many_tags"/>
                <field name="step_selection_ids" widget="many2many_tags" />
                <button name="unlink" type="object" icon="fa-trash" string="Xóa" title="Xóa Service" confirm="Bạn có chắc chắn muốn xóa Service này?"/>
            </list>
        </field>
    </record>
    <record id="view_student_service_form" model="ir.ui.view">
        <field name="name">student.service.form</field>
        <field name="model">student.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Định nghĩa dịch vụ">
                            <field name="name" />
                            <field name="description" help="Mô tả chi tiết về dịch vụ này, bao gồm các thông tin cần thiết cho sinh viên"/>
                            <field name="titlenote" help="Ghi chú cho SV thông tin cần nhập như thế nào"/>
                            <field name="duration"/>
                            <field name="rating_timeout"/>
                            <field name="state"/>
                            <field name="group_id" />
                        </group>
                        <group string="Thông tin duyệt dịch vụ">
                            <field name="files" widget="many2many_tags"/>
                            <field name="step_selection_ids">
                                <list editable="bottom" default_order="sequence">
                                    <field name="sequence" widget="handle"/>
                                    <field name="step_id" required="1" options="{'no_create': true, 'no_create_edit': true}" string="Bước duyệt"/>
                                    <field name="name" string="Tên bước theo thứ tự" readonly="1"/>
                                    <field name="step_description" readonly="1"/>
                                </list>
                            </field>
                        </group>
                        <group string="Phân công duyệt">
                            <field name="users" widget="many2many_tags" domain="[('groups_id.name', '=', 'Settings')]" help="Người cụ thể nhận được thông báo duyệt dịch vụ này"/>
                            <field name="role_ids" widget="many2many_tags" help="Các vai trò nhận được thông báo duyệt dịch vụ này"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Form Fields" name="form_fields">
                            <field name="form_field_ids" nolabel="1" context="{'default_service_id': id}">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <!-- ⭐ Chọn từ Template hoặc tạo mới -->
                                    <field name="field_template_id" 
                                           placeholder="Chọn template hoặc để trống"
                                           options="{'no_create_edit': True}"/>
                                    <!-- ⭐ READONLY sau khi tạo để tránh thay đổi field key -->
                                    <field name="name" placeholder="VD: student_id" readonly="id"/>
                                    <field name="label" placeholder="VD: Mã sinh viên"/>
                                    <!-- ⭐ READONLY field_type sau khi tạo để tránh conflict -->
                                    <field name="field_type" />
                                    <field name="placeholder"/>
                                    <field name="required"/>
                                    <field name="options" invisible="field_type != 'select'" 
                                           placeholder="Mỗi dòng 1 option"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">student.service</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>