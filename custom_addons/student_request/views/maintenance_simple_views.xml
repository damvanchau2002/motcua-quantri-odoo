<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Simple Maintenance Dashboard (an toàn, không tạo bản ghi trùng khóa) -->
    <record id="view_maintenance_simple_form" model="ir.ui.view">
        <field name="name">maintenance.simple.form</field>
        <field name="model">ir.config_parameter</field>
        <field name="arch" type="xml">
            <form string="Quản lý chế độ bảo trì" create="false" edit="false" delete="false">
                <header>
                    <button name="%(action_toggle_maintenance)d" 
                            string="🔄 Bật/Tắt bảo trì" 
                            type="action" 
                            class="btn-primary"/>
                    <button name="%(action_set_maintenance_on)d" 
                            string="🔴 Bật bảo trì" 
                            type="action" 
                            class="btn-warning"/>
                    <button name="%(action_set_maintenance_off)d" 
                            string="🟢 Tắt bảo trì" 
                            type="action" 
                            class="btn-success"/>
                </header>
                <sheet>
                    <group string="Trạng thái hiện tại">
                        <field name="maintenance_status" readonly="1"/>
                        <field name="maintenance_message" readonly="1"/>
                        <field name="maintenance_duration" readonly="1"/>
                        <field name="maintenance_start_time" readonly="1"/>
                        <field name="maintenance_end_time" readonly="1"/>
                    </group>
                    <group string="Cài đặt nhanh">
                        <button name="%(action_set_duration_30min)d" 
                                string="⏰ Bảo trì 30 phút" 
                                type="action" 
                                class="btn btn-outline-primary"/>
                        <button name="%(action_set_duration_1hour)d" 
                                string="⏰ Bảo trì 1 giờ" 
                                type="action" 
                                class="btn btn-outline-primary"/>
                        <button name="%(action_set_duration_2hour)d" 
                                string="⏰ Bảo trì 2 giờ" 
                                type="action" 
                                class="btn btn-outline-primary"/>
                        <button name="%(action_set_custom_message)d" 
                                string="✏️ Tùy chỉnh thông báo" 
                                type="action" 
                                class="btn btn-outline-secondary"/>
                    </group>
                    <group string="Thông báo mẫu">
                        <button name="%(action_set_message_update)d" 
                                string="🔄 Hệ thống đang cập nhật, vui lòng quay lại sau" 
                                type="action" 
                                class="btn btn-outline-info"/>
                        <button name="%(action_set_message_maintenance)d" 
                                string="🛠️ Hệ thống đang bảo trì định kỳ" 
                                type="action" 
                                class="btn btn-outline-info"/>
                        <button name="%(action_set_message_upgrade)d" 
                                string="⬆️ Đang nâng cấp hệ thống, xin lỗi vì sự bất tiện" 
                                type="action" 
                                class="btn btn-outline-info"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action mở dashboard cho bản ghi trạng thái hiện có -->
    <record id="action_maintenance_simple_dashboard" model="ir.actions.act_window">
        <field name="name">Quản lý chế độ bảo trì</field>
        <field name="res_model">ir.config_parameter</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_maintenance_simple_form"/>
        <field name="target">current</field>
        <field name="domain">[('key', '=', 'maintenance.status')]</field>
        <field name="context">{
            'default_key': 'maintenance.status',
            'default_value': 'off'
        }</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_maintenance_root"
              name="Bảo trì hệ thống"
              parent="base.menu_administration"
              sequence="100"
              groups="base.group_system"/>

    <menuitem id="menu_maintenance_dashboard_simple"
              name="Bảng điều khiển"
              parent="menu_maintenance_root"
              action="action_maintenance_simple_dashboard"
              sequence="10"/>

</odoo>