<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Review Views -->
    <record id="view_student_service_request_review_list" model="ir.ui.view">
        <field name="name">student.service.request.review.list</field>
        <field name="model">student.service.request.review</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="request_id"/>
                <field name="user_id"/>
                <field name="review_date"/>
                <field name="rating"/>
                <field name="ispublic"/>
            </list>
        </field>
    </record>

    <record id="view_student_service_request_review_form" model="ir.ui.view">
        <field name="name">student.service.request.review.form</field>
        <field name="model">student.service.request.review</field>
        <field name="arch" type="xml">
            <form string="Đánh giá yêu cầu">
                <header>
                    <button name="action_back" string="Quay lại" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="request_id"/>
                        <field name="user_id"/>
                        <field name="review_date"/>
                        <field name="rating"/>
                        <field name="ispublic"/>
                        <field name="comments"/>
                        <field name="image_ids" widget="many2many" mode="kanban" string="Hình ảnh">
                            <kanban>
                                <field name="name"/>
                                <field name="datas"/>
                                <field name="mimetype"/>
                                <templates>
                                    <t t-name="card">
                                        <div class="oe_kanban_global_click" style="display: inline-block; margin: 5px;">
                                            <t t-if="record.mimetype.value &amp;&amp; record.mimetype.value.indexOf('image') &gt; -1">
                                                <img t-att-src="'/web/image/ir.attachment/' + record.id.raw_value + '/datas'" 
                                                    style="max-width: 150px; max-height: 150px; cursor: pointer;"/>
                                            </t>
                                            <t t-else="">
                                                <div style="width: 150px; height: 150px; display: flex; align-items: center; justify-content: center; background: #f8f9fa; border: 1px solid #dee2e6;">
                                                    <i class="fa fa-file-o" style="font-size: 48px; color: #6c757d;"></i>
                                                </div>
                                            </t>
                                            <div class="oe_kanban_details" style="text-align: center;">
                                                <field name="name"/>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                            <form>
                                <sheet>
                                    <field name="name"/>
                                    <field name="datas" widget="image"/>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Simple Action -->
    <record id="action_student_service_request_review" model="ir.actions.act_window">
        <field name="name">Đánh giá yêu cầu</field>
        <field name="res_model">student.service.request.review</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Complaint Views -->
    <record id="view_student_service_request_complaint_list" model="ir.ui.view">
        <field name="name">student.service.request.complaint.list</field>
        <field name="model">student.service.request.complaint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="request_id"/>
                <field name="user_id"/>
                <field name="complaint_date"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_student_service_request_complaint_form" model="ir.ui.view">
        <field name="name">student.service.request.complaint.form</field>
        <field name="model">student.service.request.complaint</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="request_id"/>
                        <field name="user_id"/>
                        <field name="complaint_date"/>
                        <field name="description"/>
                        <field name="image_ids" widget="many2many" mode="kanban" string="Hình ảnh">
                            <kanban>
                                <field name="name"/>
                                <field name="datas"/>
                                <field name="mimetype"/>
                                <templates>
                                    <t t-name="card">
                                        <div class="oe_kanban_global_click" style="display: inline-block; margin: 5px;">
                                            <t t-if="record.mimetype.value &amp;&amp; record.mimetype.value.indexOf('image') &gt; -1">
                                                <img t-att-src="'/web/image/ir.attachment/' + record.id.raw_value + '/datas'" 
                                                    style="max-width: 150px; max-height: 150px; cursor: pointer;"/>
                                            </t>
                                            <t t-else="">
                                                <div style="width: 150px; height: 150px; display: flex; align-items: center; justify-content: center; background: #f8f9fa; border: 1px solid #dee2e6;">
                                                    <i class="fa fa-file-o" style="font-size: 48px; color: #6c757d;"></i>
                                                </div>
                                            </t>
                                            <div class="oe_kanban_details" style="text-align: center;">
                                                <field name="name"/>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                            <form>
                                <sheet>
                                    <field name="name"/>
                                    <field name="datas" widget="image"/>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_service_request_complaint" model="ir.actions.act_window">
        <field name="name">Khiếu nại yêu cầu</field>
        <field name="res_model">student.service.request.complaint</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>