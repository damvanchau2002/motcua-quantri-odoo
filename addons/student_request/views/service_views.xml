<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- === GROUP === -->
    <record id="view_service_group_list" model="ir.ui.view">
        <field name="name">student.service.group.list</field>
        <field name="model">student.service.group</field>
        <field name="arch" type="xml">
            <list string="Danh mục">
                <field name="name"/>
                <field name="parent_id"/>
                <field name="description"/>
                <button name="action_unlink_with_children"
                        type="object"
                        icon="fa-trash"
                        string="Xóa"
                        title="Xóa nhóm (bao gồm tất cả nhóm con)"
                        confirm="Bạn có chắc chắn muốn xóa nhóm này và toàn bộ nhóm con cháu không?"/>
            </list>
        </field>
    </record>
    <record id="view_service_group_form" model="ir.ui.view">
        <field name="name">student.service.group.form</field>
        <field name="model">student.service.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Thông tin nhóm">
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="description"/>
                    </group>
                    <group string="Nhóm con" class="o_group_child_ids">
                        <field name="child_ids" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_service_group" model="ir.actions.act_window">
        <field name="name">Quản lý nhóm dịch vụ</field>
        <field name="res_model">student.service.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- === SERVICE === -->
    <record id="view_student_service_list" model="ir.ui.view">
        <field name="name">student.service.list</field>
        <field name="model">student.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="state"/>
                <field name="group_id"/>
                <field name="files" widget="many2many_tags"/>
                <field name="users" widget="many2many_tags"/>
                <field name="step_ids" widget="many2many_tags" />
                <button name="unlink" type="object" icon="fa-trash" string="Xóa" title="Xóa Service" confirm="Bạn có chắc chắn muốn xóa Service này?"/>
            </list>
        </field>
    </record>
    <record id="view_student_service_form" model="ir.ui.view">
        <field name="name">student.service.form</field>
        <field name="model">student.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Thông tin dịch vụ">
                            <field name="name" />
                            <field name="description" help="Mô tả chi tiết về dịch vụ này, bao gồm các thông tin cần thiết cho sinh viên"/>
                            <field name="titlenote" help="Ghi chú cho SV thông tin cần nhập như thế nào"/>
                            <field name="state"/>
                            <field name="group_id" />
                        </group>
                        <group string="Thông tin duyệt dịch vụ">
                            <field name="files" widget="many2many_tags"/>
                            <field name="step_ids" widget="many2many_tags"
                                domain="[]"
                                context="{'default_sequence': 1, 'default_nextstep': 99}"
                                options="{'no_create': true, 'no_create_edit': true}"
                            />
                            <field name="users" widget="many2many_tags" domain="[('groups_id.name', '=', 'Settings')]" />
                            <field name="role_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">student.service</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- === STEP === -->
    <record id="view_student_service_step_list" model="ir.ui.view">
        <field name="name">student.service.step.list</field>
        <field name="model">student.service.step</field>
        <field name="arch" type="xml">
            <list default_order="sequence">
                <field name="name"/>
                <field name="sequence"/>
                <field name="nextstep"/>
                <field name="state"/>
                <field name="user_ids" widget="many2many_tags" />
                <field name="role_ids" widget="many2many_tags"/>
                <button name="unlink" type="object" icon="fa-trash" string="Xóa" title="Xóa bước" confirm="Bạn có chắc chắn muốn xóa bước này?" invisible="state == 0"/>
            </list>
        </field>
    </record>
    <record id="view_student_service_step_form" model="ir.ui.view">
        <field name="name">student.service.step.form</field>
        <field name="model">student.service.step</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="nextstep"/>
                        <field name="description"/>
                        <field name="state"/>

                        <field name="user_ids" widget="many2many_tags"/>
                        <field name="role_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_service_step" model="ir.actions.act_window">
        <field name="name">Service Steps</field>
        <field name="res_model">student.service.step</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- === FILE === -->
    <record id="view_student_service_file_list" model="ir.ui.view">
        <field name="name">student.service.file.list</field>
        <field name="model">student.service.file</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <button name="unlink" type="object" icon="fa-trash" string="Xóa" title="Xóa File" confirm="Bạn có chắc chắn muốn xóa File này?"/>
            </list>
        </field>
    </record>
    <record id="view_student_service_file_form" model="ir.ui.view">
        <field name="name">student.service.file.form</field>
        <field name="model">student.service.file</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="unlink" type="object" icon="fa-trash" string="Xóa" title="Xóa File" confirm="Bạn có chắc chắn muốn xóa File này?"/>
                    </header>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_service_file" model="ir.actions.act_window">
        <field name="name">Files</field>
        <field name="res_model">student.service.file</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- === REQUEST === -->

    <!-- View form tạo yêu cầu dịch vụ -->           
    <record id="view_service_request_form" model="ir.ui.view">
        <field name="name">student.service.request.form</field>
        <field name="model">student.service.request</field> 
        <field name="arch" type="xml">
            <form delete="false">
                <sheet>
                    <header>
                        Tạo yêu cầu mới:
                    </header>
                    <group>
                        <group string="Nội dung yêu cầu">
                            <field name="service_id"/>
                            <field name="image_attachment_ids" widget="many2many_binary"/>
                            <field name="note"/>
                            <field name="request_user_id" domain="[('groups_id.name', '=', 'Public')]"/>
                        </group>
                        <group string="Thông tin yêu cầu">
                            <field name="name" readonly="1"/>
                            <field name="request_user_name" readonly="1"/>
                            <field name="request_user_avatar" readonly="1" widget="image" options="{'size': [48, 48]}"/>
                            <field name="request_date" readonly="1"/>
                        </group>
                        <group string="Trạng thái duyệt">
                            <field name="final_state" />
                            <field name="approve_content"/>
                            <field name="approve_date"/>
                        </group>
                         <group string="Thông tin người duyệt">
                            <field name="users" widget="many2many_tags"/>
                            <field name="role_ids" widget="many2many_tags"/>
                            <field name="approve_user_id" />
                        </group>
                    </group>

                    <group invisible="id == 0" string="Bước duyệt">
                        <field name="step_ids" widget="kanban" nolabel="1" editable="true" no_create="True" options="{'no_create': true, 'no_open': true}">
                            <kanban>
                                <templates>
                                    <t t-name="kanban-box">
                                        <div class="oe_kanban_card">
                                            <div class="oe_kanban_header">
                                                <strong><field name="base_step_id"/></strong>
                                            </div>
                                            <div>
                                                Trạng thái: 
                                                <span><field name="state"/></span>
                                            </div>
                                            <div>Nội dung duyệt: <field name="approve_content"/></div>
                                             <div>
                                                <t t-if="record.base_step_id and record.base_step_id.sequence == 1 and record.request_id and record.request_id.service_id and record.request_id.service_id.files">
                                                    <div>
                                                        <strong>Files của dịch vụ:</strong>
                                                        <ul style="padding-left: 18px;">
                                                            <t t-foreach="record.request_id.service_id.files.raw_value" t-as="file">
                                                                <li>
                                                                    <span t-esc="file.name"/>
                                                                    <span t-if="file.description"> (<t t-esc="file.description"/>)</span>
                                                                </li>
                                                            </t>
                                                        </ul>
                                                    </div>
                                                    <div>
                                                        <field name="file_checkbox_ids" widget="many2many_tags"/>
                                                    </div>
                                                </t>
                                            </div>
                                            <div class="oe_kanban_footer">
                                                <span>Người duyệt: <field name="assign_user_id" options="{'no_create': True}"/></span>
                                                <br/>
                                                <span>Lịch sử:</span>
                                                <field name="history_ids" readonly="1" nolabel="1"/>
                                                <!-- <hr/>
                                                <t t-if="record.history_ids">
                                                    <t t-foreach="record.history_ids.value" t-as="child">
                                                        <div class="oe_kanban_details">
                                                            <span class="badge"><t t-esc="child.state"/></span>
                                                            <br />
                                                            <span><t t-esc="child.note"/></span>
                                                            <br />
                                                            <span><t t-esc="child.date"/></span>
                                                        </div>
                                                    </t>
                                                </t> -->
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </field>
                    </group>
                    <group>
                        <button name="action_create_new" string="Tạo yêu cầu" type="object" class="btn-primary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View danh sách yêu cầu dịch vụ -->
    <record id="view_service_request_kanban" model="ir.ui.view">
        <field name="name">student.service.request.kanban</field>
        <field name="model">student.service.request</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_view" default_order="id desc">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card" t-att-class="'state-' + record.final_state.value">
                            <div class="oe_kanban_details">
                                <div class="d-flex flex-column align-items-center" style="margin-right: 10px; float: right;">
                                    <field name="request_user_avatar" widget="image" options="{'size': [64, 64]}"/>
                                    <b class="mt-2"><field name="request_user_name"/></b>
                                </div>
                                <div class="oe_kanban_title">
                                    <strong>
                                        <field name="service_id"/>
                                    </strong>
                                    <br />
                                    <small><field name="note"/></small>
                                </div>
                                <div>
                                    <i class="fa fa-hourglass-half"></i>
                                    <span class="badge ms-2" t-att-class="record.final_state.raw_value == 'approved' ? 'bg-success' : (record.final_state.raw_value == 'rejected' ? 'bg-danger' : 'bg-warning')">
                                        <field name="final_state"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_date">
                                    <i class="fa fa-calendar"></i>
                                    <field name="request_date" class="ms-2"/>
                                </div>
                                <div class="oe_kanban_note">
                                    <i class="fa fa-sticky-note"></i>
                                    <field name="approve_content" class="ms-2"/>
                                </div>
                                <div class="oe_kanban_images">
                                    <b><i> Quyền duyệt: </i><br /></b>
                                    <field name="users" />
                                    <field name="role_ids"/>
                                </div>
                                <div class="oe_kanban_images">
                                    <b><i> Người đang xử lý: </i><br /></b>
                                    <field class="badge bg-secondary" name="approve_user_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Action mở form tạo yêu cầu dịch vụ -->
    <record id="action_service_request" model="ir.actions.act_window">
        <field name="name">Yêu cầu dịch vụ</field>
        <field name="res_model">student.service.request</field>
        <field name="view_mode">kanban,form</field>
        <field name="domain">[ '|', ("service_id.users", "in", [uid]), ("approve_user_id", "=", uid) ]</field>
    </record>
    
    <record id="view_student_service_request_step_history_tree" model="ir.ui.view">
        <field name="name">student.service.request.step.history.tree</field>
        <field name="model">student.service.request.step.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="state"/>
                <field name="user_id"/>
                <field name="note"/>
                <field name="date"/>
            </list>
        </field>
    </record>
    <!-- Duyệt yêu cầu dịch vụ -->
    <record id="view_student_service_request_step_form" model="ir.ui.view">
        <field name="name">student.service.request.step.form</field>
        <field name="model">student.service.request.step</field>
        <field name="arch" type="xml">
            <form string="Bước duyệt yêu cầu dịch vụ">
                <sheet>
                    <group>
                        <group string="Thông tin yêu cầu dịch vụ">
                            <field name="request_id" readonly="1"/>
                            <field name="base_step_id"  readonly="1"/>
                        </group>
                        <group string="Thông tin duyệt">
                            <field name="state"/>
                            <field name="approve_content"/>
                            <field name="assign_user_id" domain="[('groups_id.name', '=', 'Settings')]" />
                            <field name="final_data" readonly="base_secquence != 99"/>
                        </group>
                        <group string="Thông tin đính kèm">
                            <field name="file_ids" widget="many2many_tags" readonly="1" invisible="base_secquence != 1" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="file_checkbox_ids" widget="many2many_checkboxes" invisible="base_secquence != 1"/>
                        </group>
                        <group string="Lịch sử duyệt">
                            <field name="history_ids" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_confirm_approve" string="Xác nhận duyệt" type="object" class="btn-primary" confirm="Bạn có chắc chắn muốn xác nhận duyệt bước này không?"/>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_service_request_step" model="ir.actions.act_window">
        <field name="name">Bước duyệt yêu cầu dịch vụ</field>
        <field name="res_model">student.service.request.step</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Cấu hình tài khoản duyệt -->
    <record id="view_student_admin_profile_list" model="ir.ui.view">
        <field name="name">student.admin.profile.list</field>
        <field name="model">student.admin.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="title_name"/>
                <field name="activated"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="dormitory_area_id"/>
                <field name="dormitory_cluster_id"/>
                <field name="oauth_ids" />
            </list>
        </field>
    </record>
    <record id="view_student_admin_profile_form" model="ir.ui.view">
        <field name="name">student.admin.profile.form</field>
        <field name="model">student.admin.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Thông tin">
                        <field name="user_id" readonly="1"/>
                        <field name="title_name"  />
                        <field name="dormitory_area_id"  />
                        <field name="dormitory_cluster_id"  />
                        <field name="role_ids" widget="many2many_tags" options="{'no_create': True, 'no_create_edit': True}" />
                        <field name="specialization" />
                        <field name="activated"/>
                    </group>
                    <group string="Thông tin người dùng">
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="birthday"/>
                        <field name="fcm_token"/>
                        <field name="device_id"/>
                    </group>
                    <group string="Các provider đăng nhập">
                        <field name="oauth_ids" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_admin_manager_user" model="ir.actions.act_window">
        <field name="name">Admin Manager Users</field>
        <field name="res_model">student.admin.profile</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Gửi thông báo  -->
    <record id="view_student_notify_list" model="ir.ui.view">
        <field name="name">student.notify.list</field>
        <field name="model">student.notify</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="body"/>
                <field name="user_id"/>
                <field name="dormitory_cluster_ids"/>
                <field name="create_date"/>
                <field name="fcm_success_count"/>
                <field name="fcm_failure_count"/>
                <field name="fcm_responses"/>
            </list>
        </field>
    </record>
    <record id="view_student_notify_form" model="ir.ui.view">
        <field name="name">student.notify.form</field>
        <field name="model">student.notify</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Thông tin thông báo">
                        <field name="title"/>
                        <field name="body"/>
                        <field name="article" widget="textarea"/>
                        <field name="data"/>
                        <field name="image"/>
                        <hr/>
                        <field name="user_id" domain="[('groups_id.name', '=', 'Settings')]" />
                    </group>
                    <group string="Thông tin người nhận">
                        <field name="user_ids" />
                        <field name="dormitory_cluster_ids" widget="many2many_tags" options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                    <group>
                        <button name="send_fcm" string="Gửi FCM" type="object" class="btn-primary" confirm="Bạn có chắc chắn muốn gửi thông báo này không?"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_notify" model="ir.actions.act_window">
        <field name="name">Thông báo</field>
        <field name="res_model">student.notify</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Admin.OAuth -->
    <record id="view_student_admin_oauth_list" model="ir.ui.view">
        <field name="name">student.admin.oauth.list</field>
        <field name="model">student.admin.oauth</field>
        <field name="arch" type="xml">
            <list>
                <field name="profile_id"/>
                <field name="provider"/>
                <field name="token"/>
                <field name="avatar_url"/>
            </list>
        </field>
    </record>
    <record id="view_student_admin_oauth_form" model="ir.ui.view">
        <field name="name">student.admin.oauth.form</field>
        <field name="model">student.admin.oauth</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Thông tin OAuth">
                        <field name="provider"/>
                        <field name="avatar_url" />
                        <field name="token"/>
                        <field name="profile_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_student_admin_oauth" model="ir.actions.act_window">
        <field name="name">Admin OAuth</field>
        <field name="res_model">student.admin.oauth</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Dormitory -->
    <!-- Dormitory Area List & Cluster List with Sync Button -->
    <record id="view_student_dormitory_area_list" model="ir.ui.view">
        <field name="name">student.dormitory.area.list</field>
        <field name="model">student.dormitory.area</field>
        <field name="arch" type="xml">
            <list> 
                <!-- list js_class="student_dormitory_area_list_custom" -->
                <field name="name"/>
                <field name="description"/>
            </list>
            <!-- <toolbar>
                
            </toolbar> -->
        </field>
    </record>

    <record id="view_student_dormitory_area_form" model="ir.ui.view">
        <field name="name">student.dormitory.area.form</field>
        <field name="model">student.dormitory.area</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="cluster_ids">
                            <list>
                                <field name="name"/>
                                <field name="description"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <button name="action_sync_cluster"
                                type="object"
                                string="Đồng bộ"
                                class="btn-primary"
                                icon="fa-refresh"
                                confirm="Bạn có chắc chắn muốn đồng bộ dữ liệu không?"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_dormitory_area" model="ir.actions.act_window">
        <field name="name">Khu ký túc xá</field>
        <field name="res_model">student.dormitory.area</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Dormitory Cluster List & Form with Sync Button -->
    <record id="view_student_dormitory_cluster_list" model="ir.ui.view">
        <field name="name">student.dormitory.cluster.list</field>
        <field name="model">student.dormitory.cluster</field>
        <field name="arch" type="xml">
            
            <list>
                <field name="name"/>
                <field name="area_id"/>
                <field name="description"/>
            </list>
            <!-- <toolbar>
                <button name="action_sync_cluster"
                        type="object"
                        string="Đồng bộ"
                        class="btn-primary"
                        icon="fa-refresh"
                        confirm="Bạn có chắc chắn muốn đồng bộ dữ liệu không?"/>
            </toolbar> -->
        </field>
    </record>
    <record id="view_student_dormitory_cluster_form" model="ir.ui.view">
